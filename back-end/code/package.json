{
  "name": "jqtools2",
  "version": "1.0.0",
  "description": "JQ",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:renderer": "npm --prefix client run build",
    "copy:renderer": "node scripts/copy-renderer.js",
    "build": "npm run build:renderer && npm run copy:renderer && electron-builder -w",
    "build:mac": "npm run build:renderer && npm run copy:renderer && electron-builder -m"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "electron-updater": "^6.3.9",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "serialport": "^13.0.0",
    "sqlite3": "5.1.6",
    "systeminformation": "^5.27.1",
    "ws": "^8.18.2"
  },
  "build": {
    "appId": "com.bodyta.sarcopenia",
    "productName": "肌少症评估系统",
    "asar": true,
    "publish": [
      {
        "provider": "generic",
        "url": "http://sensor.bodyta.com/evaluate",
        "channel": "latest"
      }
    ],
    "win": {
      "icon": "./logo",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.58.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "@serialport/bindings-cpp",
      "electron"
    ]
  }
}
